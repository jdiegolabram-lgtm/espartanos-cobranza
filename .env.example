# ── OpenAI (L.I.N.D.A.) ───────────────────────────────────────
# Obtener en: platform.openai.com/api-keys
# Nombre de variable renombrado a LINDA_OPENAI_KEY para evitar
# conflicto con autocompletado / placeholders en plataformas de deploy.
LINDA_OPENAI_KEY=
# Modelo a usar (default: gpt-4o-mini — rápido y económico)
OPENAI_MODEL=gpt-4o-mini

# ── Email / SMTP ──────────────────────────────────────────────
# Para Outlook/Office 365:
#   SMTP_HOST=smtp.office365.com  SMTP_PORT=587  SMTP_SECURE=false
# Para Gmail:
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=cobranza@libertadfinanciera.com
SMTP_PASS=tu_contrasena_de_app
SMTP_FROM=Cobranza Libertad Financiera <cobranza@libertadfinanciera.com>

