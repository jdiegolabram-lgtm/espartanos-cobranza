# ── Supabase ──────────────────────────────────────────────────
# URL de tu proyecto en Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service Role Key (NUNCA exponerla al cliente/browser)
# Supabase → Settings → API → service_role key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Google Maps ───────────────────────────────────────────────
# Habilitar: Geocoding API en Google Cloud Console
GOOGLE_MAPS_API_KEY=AIzaSy...

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS (opcional) ───────────────────────────────────────────
# Dominio del frontend en producción
CORS_ORIGIN=https://tu-app.railway.app
